generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int           @id @default(autoincrement())
  username      String        @unique @db.VarChar(50)
  email         String        @unique @db.VarChar(255)
  passwordHash  String        @map("password_hash") @db.VarChar(255)
  roleId        Int           @map("role_id")
  createdAt     DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  role          Role          @relation(fields: [roleId], references: [id], onUpdate: NoAction)
  gameSessions  GameSession[]
  userLibraries UserLibrary[]
  wishlists     Wishlist[]
  addedGames    Game[]        @relation("UserAddedGames")

  @@map("app_user")
}

model Game {
  id            Int            @id @default(autoincrement())
  title         String         @db.VarChar(255)
  description   String?
  coverUrl      String?        @map("cover_url") @db.VarChar(500)
  igdbId        Int?           @unique @map("igdb_id")
  isCustom      Boolean        @default(false) @map("is_custom")
  addedByUserId Int?           @map("added_by_user_id")
  addedByUser   User?          @relation("UserAddedGames", fields: [addedByUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  gameSessions  GameSession[]
  priceHistory  PriceHistory[]
  userLibraries UserLibrary[]
  wishlists     Wishlist[]

  @@map("game")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model GameSession {
  id              Int       @id @default(autoincrement())
  appUserId       Int       @map("app_user_id")
  gameId          Int       @map("game_id")
  startedAt       DateTime  @map("started_at") @db.Timestamp(6)
  endedAt         DateTime? @map("ended_at") @db.Timestamp(6)
  durationMinutes Int?      @map("duration_minutes")
  appUser         User      @relation(fields: [appUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  game            Game      @relation(fields: [gameId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("game_session")
}

model Platform {
  id            Int            @id @default(autoincrement())
  name          String         @unique @db.VarChar(50)
  launchPrefix  String?        @map("launch_prefix") @db.VarChar(255)
  priceHistory  PriceHistory[]
  userLibraries UserLibrary[]

  @@map("platform")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model PriceHistory {
  id         Int       @id @default(autoincrement())
  gameId     Int       @map("game_id")
  platformId Int       @map("platform_id")
  price      Decimal   @db.Decimal(10, 2)
  recordedAt DateTime? @default(now()) @map("recorded_at") @db.Timestamp(6)
  game       Game      @relation(fields: [gameId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  platform   Platform  @relation(fields: [platformId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("price_history")
}

model Permission {
  id          Int     @id @default(autoincrement())
  action      String  @unique @db.VarChar(50)
  description String? @db.VarChar(255)
  roles       Role[]

  @@map("permission")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique @db.VarChar(50)
  users       User[]
  permissions Permission[]

  @@map("role")
}

model UserLibrary {
  id             Int       @id @default(autoincrement())
  appUserId      Int       @map("app_user_id")
  gameId         Int       @map("game_id")
  platformId     Int       @map("platform_id")
  executablePath String?   @map("executable_path") @db.VarChar(500)
  addedAt        DateTime? @default(now()) @map("added_at") @db.Timestamp(6)
  appUser        User      @relation(fields: [appUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  game           Game      @relation(fields: [gameId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  platform       Platform  @relation(fields: [platformId], references: [id], onUpdate: NoAction)

  @@unique([appUserId, gameId, platformId])
  @@map("user_library")
}

model Wishlist {
  id          Int       @id @default(autoincrement())
  appUserId   Int       @map("app_user_id")
  gameId      Int       @map("game_id")
  targetPrice Decimal?  @map("target_price") @db.Decimal(10, 2)
  addedAt     DateTime? @default(now()) @map("added_at") @db.Timestamp(6)
  appUser     User      @relation(fields: [appUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  game        Game      @relation(fields: [gameId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([appUserId, gameId])
  @@map("wishlist")
}
